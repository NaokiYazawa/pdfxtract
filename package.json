{
  "name": "pdfxtract",
  "version": "1.0.0",
  "description": "Recursively convert PDF files to TXT in a directory",
  "type": "module",
  "bin": {
    "pdfxtract": "dist/cli.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsdown",
    "check": "biome check .",
    "fix": "biome check --write .",
    "knip": "knip",
    "typecheck": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "pdf",
    "txt",
    "text",
    "converter",
    "cli"
  ],
  "author": "Naoki Yazawa",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NaokiYazawa/pdfxtract.git"
  },
  "homepage": "https://github.com/NaokiYazawa/pdfxtract#readme",
  "bugs": {
    "url": "https://github.com/NaokiYazawa/pdfxtract/issues"
  },
  "dependencies": {
    "unpdf": "^0.12.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "knip": "^5.86.0",
    "tsdown": "^0.9.0",
    "typescript": "^5.8.0"
  }
}
